# ─── SPP V2 – Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.

# General
DEBUG=true

# Database
# Dev  (SQLite – no external service required):
DATABASE_URL=sqlite:///./data_lab/spp_dev.db

# Prod (uncomment when using docker-compose PostgreSQL):
# DATABASE_URL=postgresql+psycopg2://spp:spp_secret@localhost:5432/spp

# Docker / PostgreSQL
POSTGRES_USER=spp
POSTGRES_PASSWORD=spp_secret
POSTGRES_DB=spp
DB_PORT=5432

# API
API_HOST=0.0.0.0
API_PORT=8000
